{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'$HOME/.codex/hooks/rtk-rewrite.sh'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'tell application \"Ghostty\" to activate'"
          }
        ]
      }
    ]
  }
}
